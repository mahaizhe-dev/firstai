---
const currentPath = Astro.url.pathname;
---

<header class="header">
  <div class="header-inner">
    <a href="/firstai/" class="logo">
      <span class="logo-icon"></span>
      <span class="logo-text">NEXUS</span>
    </a>
    <nav class="nav">
      <a href="/firstai/ai/" class:list={['nav-link', { active: currentPath.includes('/ai') || currentPath.includes('/tutorials') }]}>
        <span class="nav-dot ai"></span> AI
      </a>
      <a href="/firstai/world/" class:list={['nav-link', { active: currentPath.includes('/world') }]}>
        <span class="nav-dot world"></span> World
      </a>
    </nav>
  </div>
  <div class="header-glow"></div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--header-height);
    background: rgba(7, 8, 13, 0.85);
    backdrop-filter: blur(16px) saturate(180%);
    -webkit-backdrop-filter: blur(16px) saturate(180%);
    border-bottom: 1px solid var(--color-border);
  }

  @media (prefers-color-scheme: light) {
    .header {
      background: rgba(243, 244, 248, 0.85);
    }
  }

  .header-glow {
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--color-gradient);
    opacity: 0.5;
  }

  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 20px;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
    font-family: var(--font-mono);
    letter-spacing: 0.1em;
  }

  .logo-icon {
    width: 20px;
    height: 20px;
    border-radius: 6px;
    background: var(--color-gradient);
    box-shadow: 0 0 12px rgba(99, 102, 241, 0.4);
  }

  .nav {
    display: flex;
    gap: 4px;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border-radius: 6px;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: all 0.2s ease;
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
  }

  .nav-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    opacity: 0.4;
    transition: opacity 0.2s;
  }

  .nav-dot.ai { background: var(--color-accent); }
  .nav-dot.world { background: #f59e0b; }

  .nav-link:hover {
    color: var(--color-text);
    background: var(--color-glow);
  }

  .nav-link:hover .nav-dot {
    opacity: 1;
  }

  .nav-link.active {
    color: var(--color-text);
    background: var(--color-glow);
  }

  .nav-link.active .nav-dot {
    opacity: 1;
    box-shadow: 0 0 8px currentColor;
  }

  .nav-link.active .nav-dot.ai {
    box-shadow: 0 0 8px rgba(99, 102, 241, 0.6);
  }

  .nav-link.active .nav-dot.world {
    box-shadow: 0 0 8px rgba(245, 158, 11, 0.6);
  }
</style>
