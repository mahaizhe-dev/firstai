---
const currentPath = Astro.url.pathname;
---

<header class="header">
  <div class="header-inner">
    <a href="/firstai/" class="logo">
      <span class="logo-mark">//</span> FEED
    </a>
    <nav class="nav">
      <a href="/firstai/ai/" class:list={['nav-link', { active: currentPath.includes('/ai') || currentPath.includes('/tutorials') }]}>
        AI
      </a>
      <a href="/firstai/world/" class:list={['nav-link', { active: currentPath.includes('/world') }]}>
        World
      </a>
    </nav>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--header-height);
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 20px;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    font-family: var(--font-mono);
    letter-spacing: 0.06em;
  }

  .logo-mark {
    color: var(--color-accent);
  }

  .nav {
    display: flex;
    gap: 2px;
  }

  .nav-link {
    padding: 5px 12px;
    border-radius: 4px;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: all 0.15s ease;
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
  }

  .nav-link:hover {
    color: var(--color-text);
    background: var(--color-bg-secondary);
  }

  .nav-link.active {
    color: var(--color-accent);
    background: var(--color-accent-glow);
  }
</style>
