---
interface Props {
  title: string;
  description: string;
  href: string;
  date: Date;
  source?: string;
  tags?: string[];
  variant?: 'ai' | 'world' | 'tutorial' | 'history';
}

const { title, description, href, date, source, tags = [], variant = 'ai' } = Astro.props;

const formatDate = (d: Date) => {
  const now = new Date();
  const diff = now.getTime() - d.getTime();
  const hours = Math.floor(diff / (1000 * 60 * 60));
  const days = Math.floor(hours / 24);

  if (hours < 1) return '刚刚';
  if (hours < 24) return `${hours}h ago`;
  if (days < 7) return `${days}d ago`;
  return d.toLocaleDateString('zh-CN', { month: '2-digit', day: '2-digit' });
};
---

<a href={href} class:list={['card', variant]}>
  <div class="card-accent"></div>
  <div class="card-body">
    <div class="card-header">
      {variant === 'tutorial' && <span class="badge">TUTORIAL</span>}
      {source && <span class="source">{source}</span>}
      <span class="date">{formatDate(date)}</span>
    </div>
    <h3 class="card-title">{title}</h3>
    <p class="card-desc">{description}</p>
    {tags.length > 0 && (
      <div class="tags">
        {tags.slice(0, 3).map((tag) => (
          <span class:list={['tag', variant]}>{tag}</span>
        ))}
      </div>
    )}
  </div>
</a>

<style>
  .card {
    display: flex;
    position: relative;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 0;
    text-decoration: none;
    color: inherit;
    transition: all 0.25s ease;
    margin-bottom: 10px;
    overflow: hidden;
  }

  .card:hover {
    border-color: var(--color-border-hover);
    box-shadow:
      0 4px 24px var(--color-card-shadow),
      0 0 0 1px var(--color-border-hover);
    transform: translateY(-1px);
  }

  .card-accent {
    width: 3px;
    flex-shrink: 0;
    border-radius: 3px 0 0 3px;
    transition: width 0.2s ease;
  }

  .card.ai .card-accent {
    background: var(--color-gradient);
  }

  .card.world .card-accent {
    background: var(--color-gradient-warm);
  }

  .card.tutorial .card-accent {
    background: var(--color-gradient-green);
  }

  .card.history .card-accent {
    background: var(--color-gradient-purple);
  }

  .card:hover .card-accent {
    width: 4px;
  }

  .card-body {
    flex: 1;
    min-width: 0;
    padding: 14px 16px;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 6px;
    font-size: 0.6875rem;
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
  }

  .badge {
    padding: 2px 7px;
    border-radius: 4px;
    font-weight: 600;
    font-size: 0.625rem;
    letter-spacing: 0.08em;
    background: var(--color-tutorial-tag-bg);
    color: var(--color-tutorial-tag-text);
    border: 1px solid rgba(16, 185, 129, 0.2);
  }

  .source {
    color: var(--color-accent-2);
    font-weight: 500;
  }

  .date {
    color: var(--color-text-secondary);
    opacity: 0.7;
  }

  .card-title {
    font-size: 0.9375rem;
    font-weight: 600;
    line-height: 1.5;
    margin-bottom: 4px;
    color: var(--color-text);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    letter-spacing: -0.01em;
  }

  .card-desc {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 10px;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .tag {
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 0.6875rem;
    font-weight: 500;
    font-family: var(--font-mono);
    letter-spacing: 0;
  }

  .tag.ai {
    background: var(--color-tag-bg);
    color: var(--color-tag-text);
    border: 1px solid rgba(99, 102, 241, 0.15);
  }

  .tag.world {
    background: var(--color-world-tag-bg);
    color: var(--color-world-tag-text);
    border: 1px solid rgba(245, 158, 11, 0.15);
  }

  .tag.tutorial {
    background: var(--color-tutorial-tag-bg);
    color: var(--color-tutorial-tag-text);
    border: 1px solid rgba(16, 185, 129, 0.15);
  }

  .tag.history {
    background: var(--color-history-tag-bg);
    color: var(--color-history-tag-text);
    border: 1px solid rgba(168, 85, 247, 0.15);
  }
</style>
