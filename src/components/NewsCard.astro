---
interface Props {
  title: string;
  description: string;
  href: string;
  date: Date;
  source?: string;
  tags?: string[];
  variant?: 'ai' | 'world' | 'tutorial';
}

const { title, description, href, date, source, tags = [], variant = 'ai' } = Astro.props;

const formatDate = (d: Date) => {
  const now = new Date();
  const diff = now.getTime() - d.getTime();
  const hours = Math.floor(diff / (1000 * 60 * 60));
  const days = Math.floor(hours / 24);

  if (hours < 1) return 'now';
  if (hours < 24) return `${hours}h`;
  if (days < 7) return `${days}d`;
  return d.toLocaleDateString('zh-CN', { month: '2-digit', day: '2-digit' });
};

const variantIndicator: Record<string, string> = {
  ai: 'AI',
  world: 'W',
  tutorial: 'T',
};
---

<a href={href} class:list={['card', variant]}>
  <div class="card-indicator">
    <span class:list={['indicator-dot', variant]}></span>
  </div>
  <div class="card-body">
    <div class="card-header">
      {variant === 'tutorial' && <span class="badge">TUTORIAL</span>}
      {source && <span class="source">{source}</span>}
      <span class="date">{formatDate(date)}</span>
    </div>
    <h3 class="card-title">{title}</h3>
    <p class="card-desc">{description}</p>
    {tags.length > 0 && (
      <div class="tags">
        {tags.slice(0, 3).map((tag) => (
          <span class:list={['tag', variant]}>{tag}</span>
        ))}
      </div>
    )}
  </div>
</a>

<style>
  .card {
    display: flex;
    gap: 12px;
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 14px 16px;
    text-decoration: none;
    color: inherit;
    transition: all 0.15s ease;
    margin-bottom: 8px;
  }

  .card:hover {
    border-color: var(--color-accent);
    background: var(--color-accent-glow);
  }

  .card-indicator {
    flex-shrink: 0;
    padding-top: 6px;
  }

  .indicator-dot {
    display: block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-text-secondary);
  }

  .indicator-dot.ai {
    background: var(--color-accent);
  }

  .indicator-dot.world {
    background: #f59e0b;
  }

  .indicator-dot.tutorial {
    background: #10b981;
  }

  .card-body {
    flex: 1;
    min-width: 0;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 4px;
    font-size: 0.6875rem;
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
  }

  .badge {
    padding: 1px 6px;
    border-radius: 3px;
    font-weight: 600;
    font-size: 0.625rem;
    letter-spacing: 0.06em;
    background: var(--color-tutorial-tag-bg);
    color: var(--color-tutorial-tag-text);
  }

  .source {
    color: var(--color-text-secondary);
    font-weight: 500;
  }

  .date {
    color: var(--color-text-secondary);
    opacity: 0.6;
  }

  .card-title {
    font-size: 0.9375rem;
    font-weight: 600;
    line-height: 1.5;
    margin-bottom: 4px;
    color: var(--color-text);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    letter-spacing: -0.01em;
  }

  .card-desc {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 8px;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .tag {
    padding: 1px 6px;
    border-radius: 3px;
    font-size: 0.6875rem;
    font-weight: 500;
    font-family: var(--font-mono);
    letter-spacing: 0;
  }

  .tag.ai {
    background: var(--color-tag-bg);
    color: var(--color-tag-text);
  }

  .tag.world {
    background: var(--color-world-tag-bg);
    color: var(--color-world-tag-text);
  }

  .tag.tutorial {
    background: var(--color-tutorial-tag-bg);
    color: var(--color-tutorial-tag-text);
  }
</style>
