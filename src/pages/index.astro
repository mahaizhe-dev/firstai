---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import NewsCard from '../components/NewsCard.astro';
import { getCollection } from 'astro:content';

const aiNews = (await getCollection('ai-news'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const worldNews = (await getCollection('world-news'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const tutorials = (await getCollection('ai-tutorials'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 2);
---

<Layout title="首页" description="个人资讯站 - AI前沿动态与世界局势新闻">
  <Header />
  <main class="container">
    <div class="hero">
      <p class="hero-label">// PERSONAL FEED</p>
      <h1 class="hero-title">AI & World</h1>
    </div>

    <section class="section">
      <div class="section-header">
        <h2 class="section-title"><span class="title-accent">#</span> AI 前沿</h2>
        <a href="/firstai/ai/" class="section-more">all &rarr;</a>
      </div>
      {aiNews.length > 0 ? (
        aiNews.map((post) => (
          <NewsCard
            title={post.data.title}
            description={post.data.description}
            href={`/firstai/ai/${post.id}/`}
            date={post.data.pubDate}
            source={post.data.source}
            tags={post.data.tags}
            variant="ai"
          />
        ))
      ) : (
        <div class="empty-hint">暂无 AI 新闻，等待下次自动更新</div>
      )}

      {tutorials.length > 0 && (
        <div class="tutorial-preview">
          <div class="section-header" style="margin-top: 12px;">
            <h3 class="subsection-title"><span class="title-accent">&gt;</span> 工具教程</h3>
            <a href="/firstai/tutorials/" class="section-more">more &rarr;</a>
          </div>
          {tutorials.map((tut) => (
            <NewsCard
              title={tut.data.title}
              description={tut.data.description}
              href={`/firstai/tutorials/${tut.id}/`}
              date={tut.data.pubDate}
              tags={tut.data.tags}
              variant="tutorial"
            />
          ))}
        </div>
      )}
    </section>

    <section class="section">
      <div class="section-header">
        <h2 class="section-title"><span class="title-accent">#</span> 世界局势</h2>
        <a href="/firstai/world/" class="section-more">all &rarr;</a>
      </div>
      {worldNews.length > 0 ? (
        worldNews.map((post) => (
          <NewsCard
            title={post.data.title}
            description={post.data.description}
            href={`/firstai/world/${post.id}/`}
            date={post.data.pubDate}
            source={post.data.source}
            tags={post.data.tags}
            variant="world"
          />
        ))
      ) : (
        <div class="empty-hint">暂无世界新闻，等待下次自动更新</div>
      )}
    </section>

    <footer class="footer">
      <p class="footer-text">// personal feed &middot; auto-aggregated &middot; for reference only</p>
    </footer>
  </main>
</Layout>

<style>
  .hero {
    padding: 28px 0 8px;
  }

  .hero-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-accent);
    letter-spacing: 0.06em;
    margin-bottom: 4px;
  }

  .hero-title {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--color-text);
    line-height: 1.2;
  }

  .section {
    margin-bottom: 32px;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
    padding-top: 12px;
    border-top: 1px solid var(--color-border);
  }

  .section-title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  .title-accent {
    color: var(--color-accent);
    font-family: var(--font-mono);
    margin-right: 4px;
  }

  .subsection-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .section-more {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
    transition: color 0.15s;
  }

  .section-more:hover {
    color: var(--color-accent);
  }

  .empty-hint {
    padding: 32px 16px;
    text-align: center;
    color: var(--color-text-secondary);
    font-size: 0.8125rem;
    border: 1px dashed var(--color-border);
    border-radius: var(--radius);
  }

  .footer {
    text-align: center;
    padding: 32px 0;
    border-top: 1px solid var(--color-border);
    margin-top: 16px;
  }

  .footer-text {
    font-size: 0.6875rem;
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
  }
</style>
