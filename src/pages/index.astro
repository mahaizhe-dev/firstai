---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import NewsCard from '../components/NewsCard.astro';
import { getCollection } from 'astro:content';

const aiNews = (await getCollection('ai-news'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const worldNews = (await getCollection('world-news'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const tutorials = (await getCollection('ai-tutorials'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 2);
---

<Layout title="首页" description="个人资讯站 - AI前沿动态与世界局势新闻">
  <Header />
  <main class="container">
    <div class="hero">
      <div class="hero-orb"></div>
      <p class="hero-label">PERSONAL INTELLIGENCE FEED</p>
      <h1 class="hero-title">AI <span class="amp">&</span> World</h1>
      <p class="hero-desc">AI 前沿动态 · 世界局势追踪 · 自动聚合更新</p>
    </div>

    <section class="section">
      <div class="section-header">
        <h2 class="section-title">
          <span class="section-icon ai-icon"></span>
          AI 前沿
        </h2>
        <a href="/firstai/ai/" class="section-more">查看全部 &rarr;</a>
      </div>
      {aiNews.length > 0 ? (
        aiNews.map((post) => (
          <NewsCard
            title={post.data.title}
            description={post.data.description}
            href={`/firstai/ai/${post.id}/`}
            date={post.data.pubDate}
            source={post.data.source}
            tags={post.data.tags}
            variant="ai"
          />
        ))
      ) : (
        <div class="empty-hint">暂无 AI 新闻，等待下次自动更新</div>
      )}

      {tutorials.length > 0 && (
        <div class="tutorial-preview">
          <div class="section-header sub">
            <h3 class="subsection-title">
              <span class="section-icon tut-icon"></span>
              工具教程
            </h3>
            <a href="/firstai/tutorials/" class="section-more">更多教程 &rarr;</a>
          </div>
          {tutorials.map((tut) => (
            <NewsCard
              title={tut.data.title}
              description={tut.data.description}
              href={`/firstai/tutorials/${tut.id}/`}
              date={tut.data.pubDate}
              tags={tut.data.tags}
              variant="tutorial"
            />
          ))}
        </div>
      )}
    </section>

    <section class="section">
      <div class="section-header">
        <h2 class="section-title">
          <span class="section-icon world-icon"></span>
          世界局势
        </h2>
        <a href="/firstai/world/" class="section-more">查看全部 &rarr;</a>
      </div>
      {worldNews.length > 0 ? (
        worldNews.map((post) => (
          <NewsCard
            title={post.data.title}
            description={post.data.description}
            href={`/firstai/world/${post.id}/`}
            date={post.data.pubDate}
            source={post.data.source}
            tags={post.data.tags}
            variant="world"
          />
        ))
      ) : (
        <div class="empty-hint">暂无世界新闻，等待下次自动更新</div>
      )}
    </section>

    <footer class="footer">
      <div class="footer-line"></div>
      <p class="footer-text">NEXUS &middot; auto-aggregated intelligence feed</p>
    </footer>
  </main>
</Layout>

<style>
  .hero {
    position: relative;
    padding: 36px 0 24px;
    text-align: center;
    overflow: hidden;
  }

  .hero-orb {
    position: absolute;
    top: -40px;
    left: 50%;
    transform: translateX(-50%);
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.15) 0%, rgba(6, 182, 212, 0.08) 40%, transparent 70%);
    pointer-events: none;
    filter: blur(40px);
  }

  .hero-label {
    position: relative;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--color-accent-2);
    letter-spacing: 0.2em;
    margin-bottom: 8px;
    font-weight: 500;
  }

  .hero-title {
    position: relative;
    font-size: 2.5rem;
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.1;
    background: var(--color-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .amp {
    opacity: 0.5;
    font-weight: 300;
  }

  .hero-desc {
    position: relative;
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
    margin-top: 10px;
    letter-spacing: 0.02em;
  }

  .section {
    margin-bottom: 36px;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
    padding-top: 16px;
  }

  .section-header.sub {
    padding-top: 12px;
    margin-top: 8px;
  }

  .section-title {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  .section-icon {
    width: 16px;
    height: 16px;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .ai-icon { background: var(--color-gradient); }
  .world-icon { background: var(--color-gradient-warm); }
  .tut-icon { background: var(--color-gradient-green); }

  .subsection-title {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .section-more {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
    transition: color 0.2s;
    padding: 4px 10px;
    border-radius: 4px;
    border: 1px solid var(--color-border);
  }

  .section-more:hover {
    color: var(--color-accent-2);
    border-color: var(--color-border-hover);
    background: var(--color-glow);
  }

  .empty-hint {
    padding: 32px 16px;
    text-align: center;
    color: var(--color-text-secondary);
    font-size: 0.8125rem;
    border: 1px dashed var(--color-border);
    border-radius: var(--radius);
  }

  .footer {
    text-align: center;
    padding: 28px 0 32px;
    margin-top: 16px;
  }

  .footer-line {
    height: 1px;
    background: var(--color-gradient);
    opacity: 0.3;
    margin-bottom: 20px;
  }

  .footer-text {
    font-size: 0.6875rem;
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    letter-spacing: 0.08em;
  }
</style>
