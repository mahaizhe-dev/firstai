---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import TabBar from '../../components/TabBar.astro';
import NewsCard from '../../components/NewsCard.astro';
import { getCollection } from 'astro:content';

const allNews = (await getCollection('ai-news'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const tabs = [
  { label: '最新资讯', href: '/firstai/ai/', active: true },
  { label: '工具教程', href: '/firstai/tutorials/', active: false },
];
---

<Layout title="AI 前沿" description="AI 行业最新动态、模型发布、产品更新">
  <Header />
  <main class="container">
    <h1 class="page-title">AI 前沿</h1>
    <TabBar tabs={tabs} />

    {allNews.length > 0 ? (
      allNews.map((post) => (
        <NewsCard
          title={post.data.title}
          description={post.data.description}
          href={`/firstai/ai/${post.id}/`}
          date={post.data.pubDate}
          source={post.data.source}
          tags={post.data.tags}
          variant="ai"
        />
      ))
    ) : (
      <div class="empty-state">
        <p>暂无 AI 新闻</p>
        <p>等待下次自动更新，或手动触发 GitHub Actions</p>
      </div>
    )}
  </main>
</Layout>
